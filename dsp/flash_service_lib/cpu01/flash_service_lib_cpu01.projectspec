    <file action="copy" path="../../bootloader_common/include/boot_crc32.h" targetDirectory="common/include" />
    <file action="copy" path="../../bootloader_common/include/boot_metadata.h" targetDirectory="common/include" />
    <file action="copy" path="../../bootloader_common/include/boot_device_info.h" targetDirectory="common/include" />
    <file action="copy" path="../../bootloader_common/include/boot_flash_port.h" targetDirectory="common/include" />
    <file action="copy" path="../../bootloader_common/include/boot_protocol.h" targetDirectory="common/include" />
