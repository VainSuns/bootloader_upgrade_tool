    <file action="copy" path="../port/f28377d_cpu1/include/boot_flash_address_limit_f28377d_cpu1.h" targetDirectory="flash_lib/include" />

    <file action="copy" path="../../device_support/flash_api/source/Fapi_UserDefinedFunctions.c" targetDirectory="flash_lib/src" />
    <file action="copy" path="../../device_support/headers/cmd/F2837xD_Headers_nonBIOS_cpu1.cmd" targetDirectory="" />
